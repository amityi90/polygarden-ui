# Backend API base URL.
# - Local dev on the same laptop: http://localhost:5000
# - Phone on the same Wi-Fi: http://<your-laptop-LAN-IP>:5000  (e.g. http://192.168.1.42:5000)
# - Production: https://api.your-domain.com  (must be HTTPS to avoid Mixed Content blocking)
VITE_API_URL=http://localhost:5000
